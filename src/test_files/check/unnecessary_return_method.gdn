// Should warn: unnecessary return at the end of a method.
struct Foo {
  x: Int,
}

method get_x(this: Foo): Int {
  return this.x
}

// Should not warn: return is not at the end.
fun bar(b: Bool): Int {
  if b {
    return 1
  }
  2
}

// Should not warn: no return at the end.
fun baz(): Int {
  42
}

