public fun takes_options<T>(_x: Option<T>, _y: Option<T>) {}

{
    takes_options(None, None)
    takes_options(None, Some(123))

    // TODO: should be accepted by type checker.
    // takes_options(Some(123), None)

    takes_options(Some("foo"), Some(123))
}

