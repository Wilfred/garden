// Choose a random item from a list.
//
// Returns Some(item) with a random element from the provided list,
// or None if the list is empty.
//
// This is affected by the random seed set by [seed()].
public fun choice<T>(items: List<T>): Option<T> {
  let len = items.len()

  if len == 0 {
    None
  } else {
    let index = ((int() % len) + len) % len
    items.get(index)
  }
}

