let xs: List<Int> = [1, 2, 3]
if xs.len() > 0 {
  println("non-empty")
}
if xs.len() >= 1 {
  println("non-empty")
}
if xs.len() < 1 {
  println("empty")
}
if xs.len() <= 0 {
  println("empty")
}
if 0 < xs.len() {
  println("non-empty")
}

