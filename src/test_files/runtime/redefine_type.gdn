struct Foo {
  first_name: String,
}

method do_stuff(this: Foo): Int {
  123
}

struct Foo {
  name: String,
}

{
  // We should still be able to call the method after redefining the
  // type of that name.
  dbg(Foo{ name: "" }.do_stuff())
}

// args: run
// expected stderr:
// [src/test_files/runtime/redefine_type.gdn:16:3] Foo{ name: "" }.do_stuff() //-> 123

