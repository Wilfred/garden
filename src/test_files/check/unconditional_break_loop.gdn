public fun bad1() {
  while True {
    break
  }
}

public fun bad2(xs: List<Int>) {
  for x in xs {
    if x == 1 {
      break
    } else {
      break
    }
  }
}

fun get_bool(): Bool {
  False
}

public fun good1() {
  while get_bool() {
    if get_bool() {
      break
    }

    println("again")
  }
}

public fun good2() {
  while True {
    if get_bool() {
      return
    }

    break
  }
}

