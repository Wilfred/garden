import "__shell.gdn" as shell

fun main() {
  let count = match shell::get_env("COUNT") {
    Some(raw_count) => raw_count.as_int().or_throw()
    None => {
      eprintln("Environment variable COUNT is required.")
      return
    }
  }

  println("start")

  let i = 0
  while i < count {
    i += 1
  }

  println("finish")
}

main()
