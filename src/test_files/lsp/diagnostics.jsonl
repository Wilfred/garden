// Opening a file with an unbound variable produces a diagnostic, and
// fixing the file in didChange clears it.
{"jsonrpc": "2.0", "method": "textDocument/didOpen", "params": {"textDocument": {"uri": "file:///diagnostics.gdn", "languageId": "garden", "version": 1, "text": "println(no_such_var)\n"}}}
{"jsonrpc": "2.0", "method": "textDocument/didChange", "params": {"textDocument": {"uri": "file:///diagnostics.gdn", "version": 2}, "contentChanges": [{"text": "println(\"hello\")\n"}]}}

