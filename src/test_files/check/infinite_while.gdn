// Condition is a local that's never reassigned: should warn.
public fun infinite(x: Int) {
    while x < 10 {
        println("hi")
    }
}

// Condition is reassigned in the body: should not warn.
public fun terminates(x: Int): Int {
    let y = x
    while y < 10 {
        y = y + 1
    }
    y
}

// Body has a `break`: should not warn.
public fun has_break(x: Int) {
    while x < 10 {
        break
    }
}

// Condition uses `True` (a global), not a local: should not warn.
public fun while_true() {
    while True {
        break
    }
}

