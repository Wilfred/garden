// Hovering over a call to a function with a doc comment includes the
// doc comment in the hover contents.
{"jsonrpc": "2.0", "method": "textDocument/didOpen", "params": {"textDocument": {"uri": "file:///hover_doc_comment.gdn", "languageId": "garden", "version": 1, "text": "/// Add one to the given integer.\nfun add_one(x: Int): Int {\n  x + 1\n}\n\nfun main() {\n  add_one(5)\n}\n"}}}
{"jsonrpc": "2.0", "id": 1, "method": "textDocument/hover", "params": {"textDocument": {"uri": "file:///hover_doc_comment.gdn"}, "position": {"line": 6, "character": 2}}}

