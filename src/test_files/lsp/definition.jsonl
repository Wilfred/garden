// Go-to-definition on a call to a user-defined function jumps to the
// `fun` definition.
{"jsonrpc": "2.0", "method": "textDocument/didOpen", "params": {"textDocument": {"uri": "file:///definition.gdn", "languageId": "garden", "version": 1, "text": "fun add_one(i: Int): Int {\n  i + 1\n}\n\nadd_one(2)\n"}}}
{"jsonrpc": "2.0", "id": 1, "method": "textDocument/definition", "params": {"textDocument": {"uri": "file:///definition.gdn"}, "position": {"line": 4, "character": 1}}}

