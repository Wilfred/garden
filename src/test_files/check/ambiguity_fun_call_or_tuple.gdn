public fun foo() {
  let x = 1

  // Definitely a tuple, because there's whitespace before it.
  let _y = x
  (10, 11)

  // Should be parsed as a call, not an if followed by a tuple (5).
  let _: Int = if True { add_one } else { add_one }(5)
}

fun add_one(i: Int): Int {
  i + 1
}

