// Convert "+" to "+" but "/" to "slash" so we have names that are
// both valid and readable URLs
public fun operator_page_name(operator: String): String {
  if operator == "/" {
    "slash"
  } else if operator == "&&" {
    "ampamp"
  } else if operator == "||" {
    "pipepipe"
  } else if operator == "+." {
    "plusdot"
  } else if operator == "-." {
    "minusdot"
  } else if operator == "*." {
    "stardot"
  } else if operator == "/." {
    "slashdot"
  } else {
    operator
  }
}

