//  2| public fun overwritten(x: Int): Int {
//  3|     x = 1
//   |     ^^^^^
//  4|     x = 2
//  5|     x
// 
// Warning: `x` is not read after this assignment.
// --| src/test_files/check/unused_assignment.gdn:10:5
//  8| // Unused final assignment: should warn.
//  9| public fun unused_final(x: Int): Unit {
// 10|     x = 1
// 11| }   ^^^^^
// 
// Warning: `x` is not read after this assignment.
