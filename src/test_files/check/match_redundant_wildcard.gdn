enum Color {
  Red,
  Green,
  Blue,
}

public fun describe(c: Color): String {
  // The `_` case is redundant because every variant is matched.
  match c {
    Red => "red"
    Green => "green"
    Blue => "blue"
    _ => "other"
  }
}

// args: check
// expected exit status: 1
// expected stdout:
// Warning: This `_` case is redundant, as all the cases of `Color` are already matched.
// 
