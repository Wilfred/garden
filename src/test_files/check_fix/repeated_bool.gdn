public fun repeated_or(x: Bool, y: Bool): Bool {
    x || y || x
}

public fun repeated_and(x: Bool, y: Bool): Bool {
    x && y && x
}

public fun repeated_paren(a: Bool, b: Bool): Bool {
    (a || b) || a
}

