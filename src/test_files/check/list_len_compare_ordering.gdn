public fun gt_zero(xs: List<Int>): Bool {
  xs.len() > 0
}

public fun ge_one(xs: List<Int>): Bool {
  xs.len() >= 1
}

public fun lt_one(xs: List<Int>): Bool {
  xs.len() < 1
}

