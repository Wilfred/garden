// Repeated operand in ||: should warn.
fun repeated_or(x: Bool, y: Bool): Bool {
    x || y || x
}

// Repeated operand in &&: should warn.
fun repeated_and(x: Bool, y: Bool): Bool {
    x && y && x
}

// Function calls are impure: should not warn.
fun impure_or(): Bool {
    some_bool() || some_bool()
}

fun some_bool(): Bool {
    True
}

// No repeats: should not warn.
fun no_repeats(x: Bool, y: Bool, z: Bool): Bool {
    x || y || z
}

// args: check
// expected exit status: 1
// expected stdout:
// Warning: `repeated_or` is never called.
